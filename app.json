{
  "expo": {
    "name": "ATTO",
    "slug": "atto-sound",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "atto",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.atto.sound",
      "entitlements": {
        "aps-environment": "production"
      },
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Atto needs microphone access for voice calls",
        "NSPhotoLibraryUsageDescription": "ATTO needs access to your photo library to set your profile picture",
        "NSCameraUsageDescription": "ATTO needs camera access to take a profile photo",
        "UIBackgroundModes": [
          "voip",
          "audio",
          "fetch",
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.RECORD_AUDIO",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.CAMERA"
      ],
      "package": "com.atto.sound"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.atto.sound",
          "enableGooglePay": true
        }
      ],
      "expo-image-picker",
      "expo-contacts",
      "expo-asset",
      "expo-audio",
      ["expo-localization", { "supportedLocales": ["en", "es", "pt-BR"] }],
      [
        "@sentry/react-native/expo",
        {
          "organization": "atto-sound",
          "project": "react-native"
        }
      ],
      "expo-video"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c12991cf-7f27-4433-8b57-0c67648f8d6a"
      }
    }
  }
}
